---
export interface PubItem {
  title: string;
  dateYear: number;
 venue: string;
  authors: string[];
  tags: string[];
  thumbnail?: string;
  award?: string;
  links?: {
    pdf?: string;
    doi?: string;
    arxiv?: string;
    project?: string;
    video?: string;
  };
}

export interface Props {
  heading?: string;
  pubs: PubItem[];
  moreHref?: string;
}

const { heading, pubs, moreHref } = Astro.props;
const tags = Array.from(new Set(pubs.flatMap((p) => p.tags ?? []))).sort();

type IconName = "pdf" | "doi" | "arxiv" | "project" | "video";

const ICON_URL: Record<IconName, string> = {
  pdf: "/icons/pubicons/pdf.svg",
  doi: "/icons/pubicons/doi.svg",
  arxiv: "/icons/pubicons/arxiv.svg",
  project: "/icons/pubicons/project.svg",
  video: "/icons/pubicons/video.svg",
};

type LinkKey = keyof NonNullable<PubItem["links"]>;

type LinkDef = {
  key: LinkKey;
  label: string;
  icon: IconName;
};

const LINK_ORDER: LinkDef[] = [
  { key: "pdf", label: "PDF", icon: "pdf" },
  { key: "doi", label: "DOI", icon: "doi" },
  { key: "arxiv", label: "arXiv", icon: "arxiv" },
  { key: "project", label: "Project", icon: "project" },
  { key: "video", label: "Video", icon: "video" },
];
---

<section data-publist>
  {heading ? <h1>{heading}</h1> : null}

  <div class="tag-filters" data-tag-filters>
    <button type="button" class="tag-btn" data-tag="">All</button>
    {tags.map((t) => (
      <button type="button" class="tag-btn" data-tag={t.toLowerCase().trim()}>
        {t}
      </button>
    ))}
  </div>

  <ul class="pub-list" data-pub-list>
    {pubs.map((p) => (
      <li
        class="pub-item"
        data-tags={(p.tags ?? []).map((t) => t.toLowerCase().trim()).join(",")}
      >
        {p.thumbnail ? (
          <button
            type="button"
            class="pub-thumb-button"
            data-lightbox-src={p.thumbnail}
            data-lightbox-alt={`${p.title} preview image`}
            aria-label={`Open enlarged image for ${p.title}`}
          >
            <img
              class="pub-thumb"
              src={p.thumbnail}
              alt={`${p.title} thumbnail`}
              loading="lazy"
            />
          </button>
        ) : (
          <div class="pub-thumb placeholder" aria-hidden="true"></div>
        )}

        <div class="pub-body">
          <div class="pub-title">
            <strong>{p.title}</strong>
            {p.award ? <span class="award"> 🏆 {p.award}</span> : null}
          </div>

          <div class="pub-meta">
            <span class="pub-authors">
              {p.authors.map((a, i) => (
                <>
                  <span class={a.toLowerCase().includes("junze") ? "author-me" : ""}>
                    {a}
                  </span>
                  {i < p.authors.length - 1 ? ", " : ""}
                </>
              ))}
            </span>
          </div>

          <div class="pub-row">
            <span class="venue-badge">{p.venue}</span>

            {p.tags?.length ? (
              <div class="pub-tags">
                {p.tags.map((t) => (
                  <span class="pub-tag">{t}</span>
                ))}
              </div>
            ) : null}
          </div>

          <div class="pub-links">
            {LINK_ORDER.map(({ key, label, icon }) => {
              const href = p.links?.[key];
              if (!href) return null;

              return (
                <a class="pub-link" href={href} target="_blank" rel="noopener">
                  <img class="pub-link-icon" src={ICON_URL[icon]} alt="" aria-hidden="true" />
                  <span>{label}</span>
                </a>
              );
            })}
          </div>
        </div>
      </li>
    ))}
  </ul>

  {/* lightbox */}
  <div class="lightbox" data-lightbox aria-hidden="true">
    <div class="lightbox-backdrop" data-lightbox-close></div>

    <div
      class="lightbox-dialog"
      role="dialog"
      aria-modal="true"
      aria-label="Enlarged publication image"
    >
      <button
        type="button"
        class="lightbox-close"
        data-lightbox-close
        aria-label="Close enlarged image"
      >
        ×
      </button>

      <img class="lightbox-image" data-lightbox-image src="" alt="" />
    </div>
  </div>
</section>

<script is:inline>
  window.addEventListener("DOMContentLoaded", () => {
    const roots = document.querySelectorAll("[data-publist]");

    roots.forEach((root) => {
      const container = root.querySelector("[data-tag-filters]");
      const list = root.querySelector("[data-pub-list]");
      const lightbox = root.querySelector("[data-lightbox]");
      const lightboxImage = root.querySelector("[data-lightbox-image]");
      const thumbButtons = Array.from(root.querySelectorAll(".pub-thumb-button"));
      const closeButtons = Array.from(root.querySelectorAll("[data-lightbox-close]"));

      if (!container || !list) return;

      const buttons = Array.from(container.querySelectorAll("button.tag-btn"));
      const items = Array.from(list.querySelectorAll("li[data-tags]"));

      function setActive(tag) {
        buttons.forEach((b) =>
          b.setAttribute("aria-pressed", String((b.dataset.tag || "") === tag))
        );

        items.forEach((li) => {
          const tags = (li.getAttribute("data-tags") || "")
            .split(",")
            .map((x) => x.trim())
            .filter(Boolean);

          li.style.display = !tag || tags.includes(tag) ? "" : "none";
        });
      }

      function openLightbox(src, alt) {
        if (!lightbox || !lightboxImage) return;
        lightboxImage.setAttribute("src", src);
        lightboxImage.setAttribute("alt", alt || "");
        lightbox.classList.add("is-open");
        lightbox.setAttribute("aria-hidden", "false");
        document.body.style.overflow = "hidden";
      }

      function closeLightbox() {
        if (!lightbox || !lightboxImage) return;
        lightbox.classList.remove("is-open");
        lightbox.setAttribute("aria-hidden", "true");
        lightboxImage.setAttribute("src", "");
        lightboxImage.setAttribute("alt", "");
        document.body.style.overflow = "";
      }

      setActive("");

      container.addEventListener("click", (e) => {
        const btn = e.target.closest("button.tag-btn");
        if (!btn) return;

        const tag = (btn.dataset.tag || "").trim();
        const isAlreadyActive = btn.getAttribute("aria-pressed") === "true" && tag !== "";
        setActive(isAlreadyActive ? "" : tag);
      });

      thumbButtons.forEach((btn) => {
        btn.addEventListener("click", () => {
          const src = btn.getAttribute("data-lightbox-src");
          const alt = btn.getAttribute("data-lightbox-alt") || "";
          if (!src) return;
          openLightbox(src, alt);
        });
      });

      closeButtons.forEach((btn) => {
        btn.addEventListener("click", closeLightbox);
      });

      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape") {
          closeLightbox();
        }
      });
    });
  });
</script>

<style>
  /* tag filters */
  .tag-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 0.75rem 0;
  }
  .tag-btn {
    border: 1px solid currentColor;
    padding: 0.2rem 0.55rem;
    border-radius: 999px;
    background: transparent;
    cursor: pointer;
    font-size: 0.85rem;
    line-height: 1.2;
  }
  .tag-btn[aria-pressed="true"] {
    font-weight: 700;
    text-decoration: none;
  }

  /* list layout */
  .pub-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .pub-item {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 18px;
    margin: 18px 0;
    align-items: start;
  }

  /* thumbnail */
  .pub-thumb-button {
    width: 200px;
    padding: 0;
    margin: 0;
    border: none;
    background: transparent;
    display: block;
    cursor: zoom-in;
  }

  .pub-thumb {
    width: 200px;
    height: 125px;
    border-radius: 0;
    display: block;
    object-fit: cover;
    border: 1px solid rgba(0, 0, 0, 0.08);
    background: #fff;
    transition: transform 0.18s ease;
  }

  .pub-thumb-button:hover .pub-thumb {
    transform: scale(1.02);
  }

  .pub-thumb.placeholder {
    width: 200px;
    height: 125px;
    border-radius: 0;
    border: 1px dashed rgba(0, 0, 0, 0.2);
    background: rgba(0, 0, 0, 0.02);
  }

  /* text */
  .pub-body {
    min-width: 0;
  }
  .pub-title {
    font-size: 16px;
    line-height: 1.3;
    font-weight: 800;
  }
  .pub-meta {
    margin-top: 6px;
    font-size: 14px;
    line-height: 1.4;
    opacity: 0.9;
  }
  .author-me {
    font-weight: 700;
    border-bottom: 1px solid currentColor;
  }
  .award {
    font-weight: 650;
    font-size: 0.95em;
  }

  /* venue badge + tags in one row */
  .pub-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin-top: 10px;
  }
  .venue-badge {
    display: inline-flex;
    align-items: center;
    font-size: 0.85rem;
    font-weight: 800;
    padding: 4px 12px;
    border-radius: 999px;
    background: #6247b01f;
    color: #6247b0;
    border: 1px solid rgba(31, 78, 214, 0.18);
    white-space: nowrap;
  }

  .pub-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    justify-content: flex-end;
    margin-top: 0;
  }
  .pub-tag {
    font-size: 0.8rem;
    padding: 2px 10px;
    border: 1px solid rgba(0, 0, 0, 0.18);
    border-radius: 999px;
    background: transparent;
    opacity: 0.9;
    white-space: nowrap;
  }

  /* links with icons + auto separators */
  .pub-links {
    margin-top: 8px;
    font-size: 15px;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0;
  }
  .pub-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    text-decoration: none;
  }
  .pub-link:hover {
    text-decoration: underline;
  }
  .pub-link + .pub-link::before {
    content: "·";
    margin: 0 10px;
    opacity: 0.55;
    text-decoration: none;
  }
  .pub-link-icon {
    width: 14px;
    height: 14px;
    flex: 0 0 14px;
    display: inline-block;
    transform: translateY(1px);
  }

  .more-link {
    margin-top: 0.75rem;
    font-size: 0.95rem;
  }

  .pub-links .pub-link-icon {
    border-radius: 0 !important;
    overflow: visible;
    background: transparent;
    box-shadow: none;
  }

  .pub-links .pub-link-icon {
    width: 14px;
    height: 14px;
    display: inline-block;
    object-fit: contain;
  }

  /* 分隔线只在右侧 pub-body 下方 */
  .pub-item:not(:last-child) .pub-body {
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
    padding-bottom: 18px;
  }

  /* 维持每个 publication 之间的整体间距 */
  .pub-item {
    margin-bottom: 20px;
  }

  /* lightbox */
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: none;
  }

  .lightbox.is-open {
    display: block;
  }

  .lightbox-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.75);
  }

  .lightbox-dialog {
    position: relative;
    z-index: 1;
    width: fit-content;
    max-width: min(92vw, 1200px);
    max-height: 90vh;
    margin: 5vh auto;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .lightbox-image {
    display: block;
    max-width: 92vw;
    max-height: 85vh;
    object-fit: contain;
    background: white;
    border-radius: 8px;
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.28);
  }

  .lightbox-close {
    position: absolute;
    top: -12px;
    right: -12px;
    width: 40px;
    height: 40px;
    border: none;
    border-radius: 999px;
    background: white;
    color: black;
    font-size: 28px;
    line-height: 1;
    cursor: pointer;
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.2);
  }

  @media (max-width: 780px) {
    .pub-item {
      grid-template-columns: 1fr;
    }

    .pub-thumb-button,
    .pub-thumb,
    .pub-thumb.placeholder {
      width: 100%;
      max-width: 320px;
      height: auto;
    }

    .pub-row {
      flex-direction: column;
      align-items: flex-start;
    }

    .pub-tags {
      justify-content: flex-start;
    }
  }
</style>